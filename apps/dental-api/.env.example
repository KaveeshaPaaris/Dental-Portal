# Dental API — Environment Variables
# Copy this file to .env and fill in your real values

# ── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Supabase ─────────────────────────────────────────────────
# From: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── Twilio (SMS + WhatsApp + Verify OTP) ─────────────────────
# From: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_PHONE_NUMBER=+15550000000
TWILIO_WHATSAPP_NUMBER=whatsapp:+15550000000
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend (Email) ───────────────────────────────────────────
# From: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Smile Dental Clinic

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com,https://admin.yourdomain.com

# ── App ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000/admin
